cat > .gitignore << 'EOF'
# OS
.DS_Store

# Node / Frontend
node_modules/
dist/
.build/
.vite/
.next/
out/

# Python / Backend
__pycache__/
*.pyc
.venv/
.virenv/
.env
*.log
logs/
media/
worker_images/
uploads/

# ML artifacts
*.pt
*.pth
*.onnx
*.npy
embeddings*/
checkpoints/
runs/

# IDE
.vscode/
.idea/
EOF